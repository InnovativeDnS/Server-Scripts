#!/bin/bash
# =============================================
# Xubuntu 26.04 LTS - Full Server Initialization Script
# xrdp + Security + Power Optimization (Clean Version)
# =============================================

set -e  # Exit on any error

echo "=== Starting Xubuntu 26.04 Server Setup ==="

# 1. Update System
echo "=== Updating System ==="
sudo apt update && sudo apt upgrade -y

# 2. Install All Essential Packages
echo "=== Installing Server Packages ==="
sudo apt install -y curl wget git htop neofetch vim nano unzip \
                    xrdp xorgxrdp dbus-x11 \
                    openssh-server ufw fail2ban \
                    powertop tuned tuned-utils cpufrequtils ethtool

# 3. xrdp Setup
echo "=== Setting up xrdp Remote Desktop ==="
sudo adduser xrdp ssl-cert
sudo systemctl enable --now xrdp

# 4. Firewall
echo "=== Configuring Firewall ==="
sudo ufw allow 22/tcp comment "SSH"
sudo ufw allow 3389/tcp comment "xrdp"
sudo ufw --force enable

# 5. Fail2Ban Protection
echo "=== Setting up Fail2Ban (SSH + xrdp) ==="
sudo cp /etc/fail2ban/jail.conf /etc/fail2ban/jail.local 2>/dev/null || true

sudo tee -a /etc/fail2ban/jail.local > /dev/null <<EOF

[sshd]
enabled = true
port = 22
maxretry = 4
bantime = 1h
findtime = 10m

[xrdp]
enabled = true
port = 3389
filter = xrdp
logpath = /var/log/xrdp.log
maxretry = 5
bantime = 1h
findtime = 10m
EOF

sudo systemctl restart fail2ban

# 6. Power Optimizations for 24/7 Server
echo "=== Power Optimizations ==="

sudo tuned-adm profile balanced

# CPU Governor
echo "schedutil" | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor

sudo tee /etc/rc.local > /dev/null <<'EOF'
#!/bin/bash
echo "schedutil" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor
exit 0
EOF
sudo chmod +x /etc/rc.local

# Disable suspend/hibernate
sudo systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target

# Powertop auto-tune service
sudo tee /etc/systemd/system/powertop.service > /dev/null <<EOF
[Unit]
Description=Powertop auto tune
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/usr/bin/powertop --auto-tune
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
EOF
sudo systemctl enable powertop.service

# 7. Enable SSH
echo "=== Enabling SSH ==="
sudo systemctl enable --now ssh

# 8. User Aliases & Welcome
echo "=== Adding Aliases & Welcome ==="
cat >> ~/.bashrc << 'EOF'

# Server Aliases
alias update='sudo apt update && sudo apt upgrade -y'
alias ll='ls -la'

echo "=================================================="
echo "   Xubuntu 26.04 Server Ready"
echo "   RDP: Port 3389"
echo "   SSH: Port 22"
echo "=================================================="
EOF

echo ""
echo "=================================================="
echo "✅ FULL SERVER SETUP COMPLETE!"
echo "=================================================="
echo "Current IP Address: $(hostname -I | awk '{print $1}')"
echo ""
echo "Next Steps:"
echo "1. Reboot the system:   sudo reboot"
echo "2. After reboot:"
echo "   • At login screen, select 'Xfce Session'"
echo "   • Connect via Windows Remote Desktop"
echo "3. (Optional) Run 'powertop' to see live power stats"
echo ""
echo "Your server is now ready!"
echo "=================================================="
